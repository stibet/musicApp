{
  "expo": {
    "name": "Makam Coach",
    "slug": "makam-coach",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "makamcoach",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080B0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.makamcoach.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#080B0F"
      },
      "package": "com.makamcoach.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      ["expo-av", { "microphonePermission": "Makam Coach mikrofona erişmek istiyor — canlı perde analizi için gereklidir." }]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
